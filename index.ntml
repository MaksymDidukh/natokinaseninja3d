<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>NatokinaseNinja3D</title>
    <style>
        :root { --main: #00ff88; --bg: #050505; --ui-panel: rgba(0,0,0,0.6); }
        body { margin: 0; overflow: hidden; background: var(--bg); touch-action: none; user-select: none; font-family: sans-serif; transition: background 0.3s; }
        
        #ui { position: absolute; top: 20px; left: 20px; color: var(--main); pointer-events: none; z-index: 10; }
        .stats { font-size: 14px; font-weight: bold; background: var(--ui-panel); padding: 12px; border-radius: 8px; border-left: 4px solid var(--main); backdrop-filter: blur(5px); }
        
        #theme-btn { 
            position: absolute; top: 20px; right: 20px; width: 45px; height: 45px; 
            background: var(--ui-panel); border: 2px solid var(--main); border-radius: 50%;
            color: var(--main); display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 100; pointer-events: auto; font-size: 20px;
        }

        #controls { position: absolute; bottom: 40px; width: 100%; display: flex; justify-content: space-around; align-items: center; pointer-events: none; }
        #joystick { width: 110px; height: 110px; background: rgba(255,255,255,0.05); border: 2px solid var(--main); border-radius: 50%; position: relative; pointer-events: auto; }
        #stick { width: 40px; height: 40px; background: var(--main); border-radius: 50%; position: absolute; left: 35px; top: 35px; box-shadow: 0 0 15px var(--main); pointer-events: none; }
        #attack-btn { width: 90px; height: 90px; background: rgba(255, 0, 85, 0.3); border: 3px solid #ff0055; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; pointer-events: auto; text-shadow: 0 0 5px black; }
        #attack-btn:active { transform: scale(0.9); background: rgba(255, 0, 85, 0.6); }
    </style>
</head>
<body>

    <div id="ui">
        <div class="stats">
            GEO SLASHER MMO<br>
            ОЧКИ: <span id="score-val">0</span> | ОНЛАЙН: <span id="online-count">1</span>
        </div>
    </div>
    <div id="theme-btn">🌙</div>

    <div id="controls">
        <div id="joystick"><div id="stick"></div></div>
        <div id="attack-btn">УДАР</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <script type="importmap">
        { "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js" } }
    </script>

    <script type="module">
        import * as THREE from 'three';

        // --- ДАННЫЕ SUPABASE ---
        const SB_URL = 'https://olicbodhjgfotfgiodfr.supabase.co';
        const SB_KEY = 'sb_publishable_4y90bVcBOvGok71eftoLzw_G6xeP9bn';
        const sb = supabase.createClient(SB_URL, SB_KEY);

        const myId = 'p' + Math.floor(Math.random() * 10000);
        let score = 0;
        let isDark = true;
        const others = {};
        const shapes = {};

        // --- THREE.JS ОСНОВА ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x050505);
        scene.fog = new THREE.Fog(0x050505, 5, 45);
        
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
        scene.add(ambientLight);
        const sun = new THREE.PointLight(0xffffff, 100, 100);
        sun.position.set(0, 15, 5);
        scene.add(sun);

        const grid = new THREE.GridHelper(100, 50, 0x00ff88, 0x222222);
        scene.add(grid);

        // --- ИГРОК ---
        const playerGroup = new THREE.Group();
        const playerBody = new THREE.Mesh(
            new THREE.CapsuleGeometry(0.3, 0.7, 4, 10), 
            new THREE.MeshStandardMaterial({ color: 0x00ff88 })
        );
        playerBody.position.y = 0.65;
        playerGroup.add(playerBody);

        const sword = new THREE.Mesh(
            new THREE.CylinderGeometry(0.02, 0.04, 1.2), 
            new THREE.MeshBasicMaterial({ color: 0xffffff })
        );
        sword.position.set(0.4, 1.1, 0.4);
        sword.rotation.x = Math.PI/4;
        playerGroup.add(sword);
        scene.add(playerGroup);

        // --- СИНХРОННЫЕ ФИГУРЫ ---
        function getSyncPos(i) {
            return { x: Math.sin(i * 12.9) * 15, z: Math.cos(i * 78.2) * 15 };
        }

        function spawn(id, i) {
            const pos = getSyncPos(i);
            const mesh = new THREE.Mesh(
                new THREE.IcosahedronGeometry(0.5), 
                new THREE.MeshStandardMaterial({ color: 0x00ffff, wireframe: true })
            );
            mesh.position.set(pos.x, 0.6, pos.z);
            scene.add(mesh);
            shapes[id] = mesh;
        }

        for(let i=0; i<20; i++) spawn('s_'+i, i);

        function killShape(id) {
            if(shapes[id]) {
                scene.remove(shapes[id]);
                delete shapes[id];
                const idx = parseInt(id.split('_')[1]);
                setTimeout(() => { if(!shapes[id]) spawn(id, idx); }, 4000);
            }
        }

        // --- SUPABASE REALTIME ---
        const channel = sb.channel('game_sync', { config: { broadcast: { self: false }, presence: { key: myId } } });

        channel
            .on('presence', { event: 'sync' }, () => {
                const state = channel.presenceState();
                document.getElementById('online-count').innerText = Object.keys(state).length;
            })
            .on('broadcast', { event: 'move' }, ({ payload }) => {
                if(!others[payload.id]) {
                    others[payload.id] = new THREE.Mesh(new THREE.CapsuleGeometry(0.3, 0.7, 4, 8), new THREE.MeshStandardMaterial({color: 0xff0055}));
                    scene.add(others[payload.id]);
                }
                others[payload.id].position.set(payload.x, 0.65, payload.z);
                others[payload.id].rotation.y = payload.r;
            })
            .on('broadcast', { event: 'hit' }, ({ payload }) => {
                killShape(payload.sid);
            })
            .subscribe();

        // --- КНОПКА ТЕМЫ ---
        document.getElementById('theme-btn').addEventListener('click', () => {
            isDark = !isDark;
            const c = isDark ? 0x050505 : 0xeeeeee;
            scene.background.set(c);
            scene.fog.color.set(c);
            grid.material.color.set(isDark ? 0x00ff88 : 0x999999);
            document.getElementById('theme-btn').innerText = isDark ? "🌙" : "☀️";
            document.documentElement.style.setProperty('--bg', isDark ? '#050505' : '#eeeeee');
            document.documentElement.style.setProperty('--main', isDark ? '#00ff88' : '#333333');
        });

        // --- УПРАВЛЕНИЕ ---
        let moveDir = { x: 0, z: 0 };
        let isAttacking = false;
        let attackTime = 0;

        const attackBtn = document.getElementById('attack-btn');
        const stick = document.getElementById('stick');
        const joystick = document.getElementById('joystick');

        function doAttack() {
            if(isAttacking) return;
            isAttacking = true;
            attackTime = Date.now();
            
            Object.keys(shapes).forEach(id => {
                if(playerGroup.position.distanceTo(shapes[id].position) < 2.2) {
                    killShape(id);
                    score++;
                    document.getElementById('score-val').innerText = score;
                    channel.send({ type: 'broadcast', event: 'hit', payload: { sid: id } });
                    sb.from('players').upsert({ id: myId, score: score }).then();
                }
            });
            setTimeout(() => { isAttacking = false; }, 300);
        }

        attackBtn.addEventListener('touchstart', (e) => { e.preventDefault(); doAttack(); });
        attackBtn.addEventListener('mousedown', doAttack);

        joystick.addEventListener('touchmove', (e) => {
            const t = e.touches[0];
            const r = joystick.getBoundingClientRect();
            const cx = r.left + r.width/2;
            const cy = r.top + r.height/2;
            const dx = t.clientX - cx;
            const dy = t.clientY - cy;
            const dist = Math.min(Math.sqrt(dx*dx + dy*dy), 40);
            const ang = Math.atan2(dy, dx);
            
            moveDir.x = Math.cos(ang) * (dist / 40);
            moveDir.z = Math.sin(ang) * (dist / 40);
            stick.style.transform = `translate(${moveDir.x * 40}px, ${moveDir.z * 40}px)`;
        });

        const stopMove = () => { moveDir = { x: 0, z: 0 }; stick.style.transform = `translate(0,0)`; };
        joystick.addEventListener('touchend', stopMove);
        joystick.addEventListener('touchcancel', stopMove);

        // --- ЦИКЛ ---
        function animate() {
            requestAnimationFrame(animate);

            if(moveDir.x !== 0 || moveDir.z !== 0) {
                playerGroup.position.x += moveDir.x * 0.12;
                playerGroup.position.z += moveDir.z * 0.12;
                playerGroup.rotation.y = Math.atan2(-moveDir.x, -moveDir.z);
                
                channel.send({
                    type: 'broadcast',
                    event: 'move',
                    payload: { id: myId, x: playerGroup.position.x, z: playerGroup.position.z, r: playerGroup.rotation.y }
                });
            }

            if(isAttacking) {
                const p = (Date.now() - attackTime) / 300;
                sword.position.y = 1.1 - p * 1.5;
                sword.rotation.x = Math.PI/4 + p * Math.PI;
            } else {
                sword.position.set(0.4, 1.1, 0.4);
                sword.rotation.set(Math.PI/4, 0, 0);
            }

            camera.position.lerp(new THREE.Vector3(playerGroup.position.x, 7, playerGroup.position.z + 10), 0.1);
            camera.lookAt(playerGroup.position);
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    </script>
<script src="https://dmamax.netlify.app/legal-module.js"></script>

</body>
</html>
